from __future__ import annotations

import math
import os
from typing import Optional

import psycopg
from psycopg.rows import dict_row
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel, Field

app = FastAPI(title="Sovereign AI Sizing API", version="1.0.0")


# =========================
# DB Connection
# =========================

def conn():
    database_url = os.getenv("DATABASE_URL")
    if not database_url:
        raise RuntimeError("DATABASE_URL is not set")
    return psycopg.connect(database_url, row_factory=dict_row)


# =========================
# Health
# =========================

@app.get("/health")
def health():
    return {"status": "ok"}


# =========================
# Chips
# =========================

@app.get("/chips")
def list_chips(
    vendor: Optional[str] = None,
    model: Optional[str] = None,
    workload_id: Optional[str] = None,
):
    q = """
    SELECT DISTINCT c.chip_id, v.name AS vendor, c.model_name, c.variant, c.generation, c.active
    FROM chip c
    JOIN chip_vendor v ON v.vendor_id = c.vendor_id
    LEFT JOIN chip_workload_permission p
      ON p.chip_id = c.chip_id AND p.permitted = TRUE
    WHERE (%s::text IS NULL OR v.name ILIKE '%%' || %s::text || '%%')
      AND (%s::text IS NULL OR c.model_name ILIKE '%%' || %s::text || '%%')
      AND (%s::uuid IS NULL OR p.workload_id = %s::uuid)
    ORDER BY v.name, c.model_name, c.variant;
    """
    with conn() as c:
        return c.execute(q, (vendor, vendor, model, model, workload_id, workload_id)).fetchall()


# =========================
# Workloads
# =========================

@app.get("/workloads")
def list_workloads(service_class: Optional[str] = None, chip_id: Optional[str] = None):
    q = """
    SELECT DISTINCT w.workload_id, w.service_class, w.model_name, w.params_b, w.precision, w.serving_stack
    FROM model_workload w
    LEFT JOIN chip_workload_permission p
      ON p.workload_id = w.workload_id AND p.permitted = TRUE
    WHERE (%s::text IS NULL OR w.service_class = %s::text)
      AND (%s::uuid IS NULL OR p.chip_id = %s::uuid)
    ORDER BY w.service_class, w.model_name;
    """
    with conn() as c:
        return c.execute(q, (service_class, service_class, chip_id, chip_id)).fetchall()


# =========================
# Default TPS (final fallback)
# =========================

def default_tps_for_service_class(service_class: str) -> float:
    defaults = {
        "embeddings": 2000.0,
        "llm_inference": 150.0,
        "llm_training": 20.0,
    }
    return float(defaults.get(service_class, 100.0))


# =========================
# Shared Helpers
# =========================

def enforce_permission(chip_id: str, workload_id: str) -> None:
    perm_q = """
    SELECT 1
    FROM chip_workload_permission
    WHERE chip_id = %s::uuid AND workload_id = %s::uuid AND permitted = TRUE
    LIMIT 1;
    """
    with conn() as c:
        permitted = c.execute(perm_q, (chip_id, workload_id)).fetchone()
    if not permitted:
        raise HTTPException(status_code=400, detail="Chip/workload combination is not permitted")


def compute_tokens_per_sec_required(
    total_users: int,
    peak_concurrency_pct: float,
    requests_per_user_per_hour: float,
    tokens_per_request: int,
) -> tuple[float, float]:
    peak_users = total_users * peak_concurrency_pct
    requests_per_hour_total = peak_users * requests_per_user_per_hour
    tokens_per_hour_required = requests_per_hour_total * tokens_per_request
    tokens_per_sec_required = tokens_per_hour_required / 3600.0
    return tokens_per_sec_required, peak_users


def lookup_tps_per_gpu(
    chip_id: str,
    workload_id: str,
    context_len: int,
    output_len: int,
    batch_size: int,
    concurrency: int,
) -> tuple[float, str, float, str]:
    # Determine service_class
    with conn() as c:
        svc_row = c.execute(
            "SELECT service_class FROM model_workload WHERE workload_id=%s::uuid;",
            (workload_id,),
        ).fetchone()
    service_class = svc_row["service_class"] if svc_row else "llm_inference"

    # Tiered benchmark fallback
    bench_q = """
    WITH exact AS (
      SELECT pb.*, 'exact'::text AS match_type
      FROM perf_benchmark pb
      WHERE pb.chip_id=%s::uuid
        AND pb.workload_id=%s::uuid
        AND pb.context_len=%s
        AND pb.output_len=%s
        AND pb.batch_size=%s
        AND pb.concurrency=%s
      ORDER BY pb.last_validated_date DESC
      LIMIT 1
    ),
    chip_workload AS (
      SELECT pb.*, 'nearest_knobs'::text AS match_type
      FROM perf_benchmark pb
      WHERE pb.chip_id=%s::uuid
        AND pb.workload_id=%s::uuid
      ORDER BY pb.last_validated_date DESC
      LIMIT 1
    ),
    chip_service AS (
      SELECT pb.*, 'chip_service_class'::text AS match_type
      FROM perf_benchmark pb
      JOIN model_workload w ON w.workload_id=pb.workload_id
      WHERE pb.chip_id=%s::uuid
        AND w.service_class=%s
      ORDER BY pb.last_validated_date DESC
      LIMIT 1
    ),
    global_service AS (
      SELECT pb.*, 'global_service_class'::text AS match_type
      FROM perf_benchmark pb
      JOIN model_workload w ON w.workload_id=pb.workload_id
      WHERE w.service_class=%s
      ORDER BY pb.last_validated_date DESC
      LIMIT 1
    )
    SELECT * FROM exact
    UNION ALL
    SELECT * FROM chip_workload
    UNION ALL
    SELECT * FROM chip_service
    UNION ALL
    SELECT * FROM global_service
    LIMIT 1;
    """

    with conn() as c:
        row = c.execute(
            bench_q,
            (
                chip_id,
                workload_id,
                context_len,
                output_len,
                batch_size,
                concurrency,
                chip_id,
                workload_id,
                chip_id,
                service_class,
                service_class,
            ),
        ).fetchone()

    if row:
        tps_per_gpu = float(row["tps_per_gpu"])
        match_type = row["match_type"]
        confidence = float(row.get("confidence_score", 1))
        return tps_per_gpu, match_type, confidence, service_class

    # Final fallback
    return default_tps_for_service_class(service_class), "default_assumed", 0.0, service_class


# =========================
# Sizing Models: GPUaaS
# =========================

class GpuAasSizeRequest(BaseModel):
    chip_id: str
    workload_id: str

    total_users: int = Field(..., ge=1)
    peak_concurrency_pct: float = Field(..., ge=0, le=1)
    requests_per_user_per_hour: float = Field(..., ge=0)
    tokens_per_request: int = Field(..., ge=1)

    context_len: int = Field(8192, ge=1)
    output_len: int = Field(256, ge=1)
    batch_size: int = Field(1, ge=1)
    concurrency: int = Field(10, ge=1)

    target_utilization: float = Field(0.70, gt=0, le=1)
    resilience_factor: float = Field(1.20, ge=1.0)


class GpuAasSizeResponse(BaseModel):
    tokens_per_sec_required: float
    tps_per_gpu: float
    gpu_raw: float
    gpu_adjusted_for_utilization: float
    gpu_total_with_resilience: int
    assumptions: dict
    calculator_details: dict


# =========================
# Sizing Models: LLM Token Factor
# =========================

class LlmTokenFactorRequest(BaseModel):
    chip_id: str
    workload_id: str

    total_users: int = Field(..., ge=1)
    peak_concurrency_pct: float = Field(..., ge=0, le=1)
    requests_per_user_per_hour: float = Field(..., ge=0)
    tokens_per_request: int = Field(..., ge=1)

    context_len: int = Field(8192, ge=1)
    output_len: int = Field(256, ge=1)
    batch_size: int = Field(1, ge=1)
    concurrency: int = Field(10, ge=1)

    target_utilization: float = Field(0.70, gt=0, le=1)
    resilience_factor: float = Field(1.20, ge=1.0)

    # Optional: evaluate an existing fleet capacity
    installed_gpus: Optional[int] = Field(None, ge=1)


class LlmTokenFactorResponse(BaseModel):
    tokens_per_sec_required: float
    tps_per_gpu: float

    installed_gpus: int
    effective_gpus_after_resilience: float
    tokens_per_sec_capacity: float

    token_factor: float
    headroom_pct: float

    assumptions: dict
    calculator_details: dict


# =========================
# Endpoint: LLM Token Factor
# =========================

@app.post("/size/llm-token-factor", response_model=LlmTokenFactorResponse)
def llm_token_factor(req: LlmTokenFactorRequest):
    enforce_permission(req.chip_id, req.workload_id)

    tokens_per_sec_required, peak_users = compute_tokens_per_sec_required(
        req.total_users,
        req.peak_concurrency_pct,
        req.requests_per_user_per_hour,
        req.tokens_per_request,
    )

    tps_per_gpu, match_type, confidence, service_class = lookup_tps_per_gpu(
        req.chip_id,
        req.workload_id,
        req.context_len,
        req.output_len,
        req.batch_size,
        req.concurrency,
    )

    # If installed_gpus is not provided, derive a baseline fleet size from sizing math
    if req.installed_gpus is None:
        gpu_raw = tokens_per_sec_required / tps_per_gpu if tps_per_gpu > 0 else 0.0
        gpu_adj = gpu_raw / req.target_utilization
        installed_gpus = int(math.ceil(gpu_adj * req.resilience_factor))
        installed_mode = "derived_from_sizing"
    else:
        installed_gpus = int(req.installed_gpus)
        installed_mode = "user_provided"

    # Capacity = (installed ÷ resilience) × TPS/GPU × target util
    effective_gpus = installed_gpus / req.resilience_factor if req.resilience_factor > 0 else 0.0
    tokens_per_sec_capacity = effective_gpus * tps_per_gpu * req.target_utilization

    if tokens_per_sec_capacity > 0:
        token_factor = tokens_per_sec_required / tokens_per_sec_capacity
        headroom_pct = (1.0 - token_factor) * 100.0
    else:
        token_factor = float("inf")
        headroom_pct = -100.0

    return LlmTokenFactorResponse(
        tokens_per_sec_required=tokens_per_sec_required,
        tps_per_gpu=tps_per_gpu,
        installed_gpus=installed_gpus,
        effective_gpus_after_resilience=effective_gpus,
        tokens_per_sec_capacity=tokens_per_sec_capacity,
        token_factor=token_factor,
        headroom_pct=headroom_pct,
        assumptions={
            "peak_users": peak_users,
            "benchmark_match_type": match_type,
            "benchmark_confidence_score": confidence,
            "service_class": service_class,
            "installed_gpus_mode": installed_mode,
            "capacity_formula_notes": "capacity = (installed_gpus / resilience_factor) × tps_per_gpu × target_utilization",
        },
        calculator_details={
            "formulas": {
                "tokens_per_sec_required": "(users × concurrency × req/hr × tokens) / 3600",
                "tokens_per_sec_capacity": "(installed_gpus ÷ resilience_factor) × tps_per_gpu × target_utilization",
                "token_factor": "tokens_per_sec_required ÷ tokens_per_sec_capacity",
                "headroom_pct": "(1 − token_factor) × 100",
            }
        },
    )


# =========================
# Endpoint: GPUaaS Sizing
# =========================

@app.post("/size/gpu-aas", response_model=GpuAasSizeResponse)
def size_gpu_aas(req: GpuAasSizeRequest):
    enforce_permission(req.chip_id, req.workload_id)

    tokens_per_sec_required, peak_users = compute_tokens_per_sec_required(
        req.total_users,
        req.peak_concurrency_pct,
        req.requests_per_user_per_hour,
        req.tokens_per_request,
    )

    tps_per_gpu, match_type, confidence, _service_class = lookup_tps_per_gpu(
        req.chip_id,
        req.workload_id,
        req.context_len,
        req.output_len,
        req.batch_size,
        req.concurrency,
    )

    gpu_raw = tokens_per_sec_required / tps_per_gpu if tps_per_gpu > 0 else 0.0
    gpu_adj = gpu_raw / req.target_utilization
    gpu_total = int(math.ceil(gpu_adj * req.resilience_factor))

    return GpuAasSizeResponse(
        tokens_per_sec_required=tokens_per_sec_required,
        tps_per_gpu=tps_per_gpu,
        gpu_raw=gpu_raw,
        gpu_adjusted_for_utilization=gpu_adj,
        gpu_total_with_resilience=gpu_total,
        assumptions={
            "peak_users": peak_users,
            "benchmark_match_type": match_type,
            "benchmark_confidence_score": confidence,
        },
        calculator_details={
            "formulas": {
                "tokens_per_sec_required": "(users × concurrency × req/hr × tokens) / 3600",
                "gpu_raw": "tokens_per_sec_required ÷ tps_per_gpu",
                "gpu_adj": "gpu_raw ÷ target_utilization",
                "gpu_total": "ceil(gpu_adj × resilience_factor)",
            }
        },
    )